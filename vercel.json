{
  "crons": [
    {
      "path": "/api/cron/expire-abonnements",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/rappel-expiration",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/lonaci-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/lonaci-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/lonaci-sync",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/lonaci-sync",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/pmu-sync",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/lonaci-sync",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/geny-arrivees",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/geny-arrivees",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/geny-arrivees",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/geny-arrivees",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/admin/sync-resultats",
      "schedule": "0 21 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
